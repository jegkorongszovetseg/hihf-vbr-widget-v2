{
  "name": "@mjsz-vbr-elements/monorepo",
  "type": "module",
  "version": "2.45.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "Data visualization for MJSZ VBR",
  "author": "Ákos Stegner <akos.stegner@gmail.com>",
  "license": "ISC",
  "keywords": [],
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "packages/*",
    "playground/**",
    "histoire/**"
  ],
  "scripts": {
    "playground": "pnpm run -C playground dev",
    "playground:localhost": "pnpm run -C playground dev --mode localhost",
    "build": "pnpm -r --filter='./packages/*' run build",
    "test": "vitest",
    "test:ci": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "pnpm run lint:fix && pnpm test:ci && pnpm run build && bumpp -r --all",
    "publish:release": "pnpm run build && pnpm -r publish --access public"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "@vue/test-utils": "^2.4.6",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.3",
    "eslint-plugin-format": "^2.0.1",
    "happy-dom": "^20.8.4",
    "lint-staged": "^16.3.3",
    "simple-git-hooks": "^2.13.1",
    "vite-plugin-compression2": "^2.5.1",
    "vitest": "^4.1.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
