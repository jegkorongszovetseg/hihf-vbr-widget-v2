{
  "name": "@mjsz-vbr-elements/core",
  "type": "module",
  "version": "2.43.1",
  "private": false,
  "description": "Data visualization for MJSZ VBR",
  "author": "Ákos Stegner <akos.stegner@gmail.com>",
  "license": "MIT",
  "homepage": "https://api.icehockey.hu/widgets/docs/v2/",
  "repository": {
    "type": "git",
    "url": "https://github.com/jegkorongszovetseg/hihf-vbr-widget-v2.git"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./components": {
      "import": "./dist/components.js"
    },
    "./composables": {
      "import": "./dist/composables.js"
    },
    "./utils": {
      "import": "./dist/utils.js"
    },
    "./constants": {
      "import": "./dist/constants.js"
    },
    "./columns": {
      "import": "./dist/columns.js"
    },
    "./props": {
      "import": "./dist/props.js"
    }
  },
  "module": "./dist/index.js",
  "unpkg": "./dist/index.iife.js",
  "jsdelivr": "./dist/index.iife.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run build:esm && pnpm run build:browser",
    "build:esm": "vite build",
    "build:browser": "vite build -c ./build-browser.config.js --emptyOutDir false"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@lostui/utils": "^0.0.4",
    "@mjsz-vbr-elements/shared": "workspace:^",
    "@vueuse/core": "^14.2.1",
    "@xstate/fsm": "^2.1.0",
    "dayjs": "^1.11.20",
    "ramda": "^0.32.0",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "vite": "^8.0.0",
    "vite-plugin-banner": "^0.8.1",
    "vite-plugin-compression2": "^2.5.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
